# ── Supabase (waitlist storage) ─────────────────────────────
# Project URL and the SERVICE ROLE key (server-only, never expose to the client).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (confirmation emails) ────────────────────────────
# Optional: if unset, signups are stored but no confirmation email is sent.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a verified sender/domain in Resend.
RESEND_FROM=Stars Alike <hola@starsalike.app>

# ── Site ────────────────────────────────────────────────────
# Canonical public URL, used for metadata / OG / sitemap / robots.
NEXT_PUBLIC_SITE_URL=https://starsalike.app
